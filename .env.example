# Copy to .env (gitignored). Never commit .env.

# Host "docker" group GID — required so the Coder container can use /var/run/docker.sock (workspaces + Terraform).
# Linux/WSL:  getent group docker | cut -d: -f3
# Any OS with Docker:  docker run --rm -v /var/run/docker.sock:/var/run/docker.sock alpine stat -c '%g' /var/run/docker.sock
# If unset, compose defaults to 999 (common but not universal — set explicitly if provisioner gets "permission denied").
DOCKER_GROUP=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ngrok: Dashboard → Authtoken (same value works for CLI `ngrok config add-authtoken`)
NGROK_AUTH_TOKEN=

# ngrok: Dashboard → Domains → static domain (hostname only, no https://)
NGROK_DOMAIN=

# Must be https://<same host as NGROK_DOMAIN> — GitHub OAuth callbacks use this host
CODER_ACCESS_URL=
