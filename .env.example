# Copy to .env (gitignored). Never commit .env.

# docker-compose substitutes ${ANTHROPIC_API_KEY} etc. If a key is missing, Compose prints a warning and passes an empty value — set variables here to silence that and to pass values into the Coder container.

# docker-compose.yml mounts the Docker socket and C:/Users/admin/.kube → /home/coder/.kube (edit compose if your path differs).
# For docker-dev workspaces, Terraform still uses TCP — Docker Desktop → General → "Expose daemon on tcp://localhost:2375".

# GitHub OAuth "Coder Local" — login to Coder (Authorization callback URL in GitHub app settings):
#   https://<CODER_HOST>/api/v2/users/oauth2/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub OAuth "Coder Local External" — Git/external auth in workspaces (separate app; callback):
#   https://<CODER_HOST>/external-auth/github/callback
# External-auth scopes live in docker-compose (repo read:org write:public_key). Re-auth after changes.
# After scope changes, re-authorize GitHub under Coder Account → Authentication.
GITHUB_EXTERNAL_CLIENT_ID=
GITHUB_EXTERNAL_CLIENT_SECRET=

# ngrok: Dashboard → Authtoken (same value works for CLI `ngrok config add-authtoken`)
NGROK_AUTH_TOKEN=

# ngrok: Dashboard → Domains → static domain (hostname only, no https://)
NGROK_DOMAIN=

# Must be https://<same host as NGROK_DOMAIN> — GitHub OAuth callbacks use this host
CODER_ACCESS_URL=

# Wildcard hostname for workspace app subdomains (Claude Code button, embedded apps). No scheme — e.g. *.localhost:3000 with http://localhost:3000. With ngrok, use a pattern your tunnel supports.
# Leave unset to default to *.localhost:3000 from docker-compose.yml.
# Windows: browsers do not resolve arbitrary *.localhost like Linux. Add each app host to C:\Windows\System32\drivers\etc\hosts (127.0.0.1 ccw--<user>--<workspace>.localhost) or use a local DNS tool (e.g. Acrylic). See README "Embedded workspace apps on Windows".
CODER_WILDCARD_ACCESS_URL=

# Anthropic — optional in compose (silences "variable is not set" warning). k8s-dev workspaces still need the Kubernetes secret anthropic-api-key for pod env.
ANTHROPIC_API_KEY=
